{
  "name": "polymarket-trader-mcp",
  "version": "1.0.8",
  "description": "MCP server for Polymarket — trade, analyze markets, copy top traders, and manage your portfolio via AI",
  "main": "dist/index.js",
  "bin": {
    "polymarket-trader-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "type": "module",
  "keywords": [
    "mcp",
    "polymarket",
    "trading",
    "prediction-markets",
    "copy-trading",
    "ai-agent",
    "smart-money"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/demwick/polymarket-trader-mcp.git"
  },
  "homepage": "https://github.com/demwick/polymarket-trader-mcp#readme",
  "bugs": {
    "url": "https://github.com/demwick/polymarket-trader-mcp/issues"
  },
  "author": "demwick",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    ".env.example"
  ],
  "dependencies": {
    "@ethersproject/wallet": "^5.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@polymarket/clob-client": "^5.8.1",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
